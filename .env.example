# =============================================================================
# 企业微信身份（必填）
# =============================================================================

# 企业 ID：管理后台 -> 我的企业 -> 企业信息
CORP_ID=

# 会话内容存档 Secret：管理后台 -> 安全与管理 -> 管理工具 -> 会话内容存档
# 注意：不是普通自建应用 Secret
MSGAUDIT_SECRET=

# 客户联系可调用应用 Secret：用于获取外部客户群详情
# 管理后台 -> 客户联系 -> 客户 -> API -> 可调用应用
EXTERNAL_CONTACT_SECRET=

# =============================================================================
# SDK 与解密（路径可自定义）
# =============================================================================

# 企业微信官方 SDK 动态库（Linux）
# 下载地址：https://developer.work.weixin.qq.com/document/path/91774
SDK_LIB_PATH=./libWeWorkFinanceSdk_C.so

# 与管理后台"会话内容存档-公钥"配套的 RSA 私钥
PRIVATE_KEY_PATH=./private_key.pem

# =============================================================================
# 拉取与持久化
# =============================================================================

# 拉取进度文件（断点续传）
SEQ_FILE=./wecom_msg_seq.txt

# 解密消息输出文件（JSONL）
OUTPUT_JSONL=./wecom_messages.jsonl

# 单次拉取条数（最大 1000）
FETCH_LIMIT=100

# SDK 请求超时（秒）
SDK_TIMEOUT=30

# =============================================================================
# 代理（按需）
# =============================================================================
PROXY=
PROXY_PASSWORD=

# =============================================================================
# Cloudflare R2（图片等媒体上传与预签名链接）
# 留空则下载的非图片文件仅保存到本地
# =============================================================================

# R2 S3 兼容端点，可带 bucket 路径：
#   https://<accountid>.r2.cloudflarestorage.com/<bucket>
R2_ENDPOINT=
R2_BUCKET=

# 可选：用于替换预签名 URL 域名的自定义 CDN 域名
R2_CUSTOM_DOMAIN=

# S3 兼容 AccessKey
R2_S3_ID=
R2_S3_KEY=

# =============================================================================
# MCP 服务
# =============================================================================

# stdio / http
MCP_TRANSPORT=stdio

# HTTP 模式监听地址
MCP_HOST=127.0.0.1
MCP_PORT=8331

# HTTP 模式 Bearer 鉴权 Token
# 留空时启动时自动生成（仅本次进程有效，不再持久化到 .env）
MCP_BEARER_TOKEN=
